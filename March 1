Approach 2: Brute force(O(n2))
/**
 * @param {string} s
 * @param {string} goal
 * @return {boolean}
 */
var rotateString = function(s, goal) {
if(s.length!==goal.length) return false;
    for(let i=0;i<s.length;i++){
        let finalStr=s.slice(i)+s.slice(0,i);
        if(finalStr===goal) return true;
    }
   return false;
};

