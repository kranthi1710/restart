//Monotonic array

/**
 * @param {number[]} nums
 * @return {boolean}
 */
var isMonotonic = function(nums) {
  let dec=inc=true;
for(let i=1;i<nums.length;i++){
    if(nums[i] > nums[i-1]) dec=false;
    if(nums[i] < nums[i-1]) inc=false;

  }
 return inc || dec;
};

I track whether the array can still be increasing or decreasing while iterating once.
If either condition remains valid by the end, the array is monotonic. This gives O(n) time and O(1) space.
